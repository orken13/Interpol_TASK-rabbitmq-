# PostgreSQL Veritabanı Ayarları
DB_HOST=postgres
DB_PORT=5432
DB_NAME=interpol_db
DB_USER=interpol_user
DB_PASSWORD=interpol_pass

# RabbitMQ Ayarları
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=deneme103
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Flask Ayarları
FLASK_ENV=production
SECRET_KEY=your_secret_key_here

# Logging Ayarları
LOG_LEVEL=INFO